# MongoDB connection string
# Local example:      mongodb://127.0.0.1:27017/studysync
# Atlas example:       mongodb+srv://<username>:<password>@cluster0.mongodb.net/studysync
MONGO_URI=your_mongodb_connection_string_here

# Secret key used to sign JWT auth tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Port the backend server runs on
PORT=5000

# Comma-separated list of allowed frontend origins for CORS
CLIENT_URL=http://localhost:5173
